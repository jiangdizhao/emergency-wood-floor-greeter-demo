# Local-only TTS settings.
# Never commit a real API key.
# Recommended: set these variables in PowerShell before starting uvicorn.

# Local Kokoro TTS service. Run local_tts/kokoro_tts_server.py in the kokoro-tts conda env.
LOCAL_TTS_URL=http://127.0.0.1:8010/tts
LOCAL_TTS_HEALTH_URL=http://127.0.0.1:8010/health
LOCAL_TTS_TIMEOUT_SECONDS=45

# OpenAI TTS fallback. Leave OPENAI_API_KEY empty if not used.
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
